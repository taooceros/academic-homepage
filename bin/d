#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
usage:
  d              create/open today's diary in Zed
  d open [DATE]  create/open DATE's diary in Zed
  d new [DATE]   create DATE's diary if missing, print path
  d path [DATE]  print DATE's diary path
  d s            add diary, commit with current date, push
  d sync         add diary, commit with current date, push

DATE defaults to today and must be YYYY-MM-DD.
EOF
}

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
diary_dir=${DIARY_DIR:-$repo_root/content/diary}

cmd=${1:-open}
case "$cmd" in
  -h|--help|help)
    usage
    exit 0
    ;;
  open|new|path|sync|s)
    shift || true
    ;;
  *)
    # Treat a bare date as "open DATE".
    if printf '%s\n' "$cmd" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
      set -- "$cmd" "$@"
      cmd=open
    else
      printf 'unknown diary command: %s\n\n' "$cmd" >&2
      usage >&2
      exit 64
    fi
    ;;
esac

if [ "$cmd" = sync ] || [ "$cmd" = s ]; then
  mkdir -p "$diary_dir"

  case "$diary_dir" in
    "$repo_root"/*) diary_path=${diary_dir#"$repo_root"/} ;;
    "$repo_root") diary_path=. ;;
    *) diary_path=$diary_dir ;;
  esac

  git -C "$repo_root" add "$diary_path"

  modified_dates=
  for path in $(git -C "$repo_root" diff --cached --name-only -- "$diary_path"); do
    name=${path##*/}
    modified_date=${name%.typ}
    if [ "$name" != "$modified_date" ] &&
      printf '%s\n' "$modified_date" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
      if [ -z "$modified_dates" ]; then
        modified_dates=$modified_date
      else
        modified_dates="$modified_dates, $modified_date"
      fi
    fi
  done

  if ! git -C "$repo_root" diff --cached --quiet -- "$diary_path"; then
    commit_msg="diary: $(date +%F)"
    if [ -n "$modified_dates" ]; then
      commit_msg="$commit_msg ($modified_dates)"
    fi
    git -C "$repo_root" commit -m "$commit_msg" -- "$diary_path"
  fi

  git -C "$repo_root" push
  exit 0
fi

date_arg=${1:-$(date +%F)}
if ! printf '%s\n' "$date_arg" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
  printf 'diary date must be YYYY-MM-DD: %s\n' "$date_arg" >&2
  exit 64
fi

file=$diary_dir/$date_arg.typ

case "$cmd" in
  path)
    printf '%s\n' "$file"
    exit 0
    ;;
esac

mkdir -p "$diary_dir"
if [ ! -e "$file" ]; then
  printf '= %s\n\n' "$date_arg" > "$file"
fi

case "$cmd" in
  new)
    printf '%s\n' "$file"
    ;;
  open)
    exec zed "$file"
    ;;
esac
