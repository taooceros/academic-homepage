---
import Layout from "../layouts/Layout.astro";
import { readdirSync, readFileSync } from "node:fs";
import { Buffer } from "node:buffer";

type DiarySource = {
    date: Date;
    dateKey: string;
    source: string;
};

type ClientDiarySource = {
    dateKey: string;
    source: string;
};

const diaryDir = new URL("../../content/diary/", import.meta.url);
const gitCryptHeader = Buffer.from([0, 71, 73, 84, 67, 82, 89, 80, 84, 0]);

const entries = readdirSync(diaryDir)
    .filter((fileName) => fileName.endsWith(".typ"))
    .map((fileName): DiarySource | null => {
        const dateKey = fileName.match(/^(\d{4}-\d{2}-\d{2})\.typ$/)?.[1];
        if (!dateKey) {
            return null;
        }

        const bytes = readFileSync(new URL(fileName, diaryDir));
        const isEncrypted =
            bytes.length >= gitCryptHeader.length &&
            bytes.subarray(0, gitCryptHeader.length).equals(gitCryptHeader);

        return {
            date: new Date(`${dateKey}T00:00:00`),
            dateKey,
            source: isEncrypted
                ? `git-crypt:v1:${Buffer.from(bytes).toString("base64")}`
                : new TextDecoder("utf-8", { fatal: true }).decode(bytes),
        };
    })
    .filter((entry): entry is DiarySource => entry !== null)
    .sort((a, b) => b.date.getTime() - a.date.getTime());

const shortDateFormatter = new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
});

const clientEntries: ClientDiarySource[] = entries.map(
    ({ dateKey, source }) => ({
        dateKey,
        source,
    }),
);

const clientEntriesJson = JSON.stringify(clientEntries).replace(
    /</g,
    "\\u003c",
);
const initialVisibleDateKeys = new Set(
    entries.slice(0, 1).map((entry) => entry.dateKey),
);
const minDiaryDateKey = entries.at(-1)?.dateKey;
const maxDiaryDateKey = entries[0]?.dateKey;
---

<Layout
    title="Diary - Hongtao Zhang"
    description="Diary entries by Hongtao Zhang"
>
    <main>
        <section class="mb-12">
            <p
                class="text-sm uppercase tracking-[0.25em] text-(--gray-color) mb-3"
            >
                Journal
            </p>
            <h1 class="component-title mb-4">Diary</h1>
        </section>

        <form
            id="diary-key-form"
            class="mb-10 rounded-2xl border border-black/10 bg-white/45 p-4 shadow-sm md:flex md:items-end md:gap-3"
        >
            <label class="block grow">
                <span
                    class="mb-2 block text-sm font-medium text-(--gray-color)"
                >
                    Decipher key
                </span>
                <input
                    id="diary-key"
                    name="key"
                    type="password"
                    autocomplete="current-password"
                    class="w-full rounded-xl border border-black/10 bg-[#fffdf7] px-4 py-3 text-base outline-none transition-colors focus:border-black/30"
                    placeholder="Enter key to render diary"
                    required
                />
            </label>
            <button
                type="submit"
                class="mt-3 rounded-xl bg-(--main-color) px-5 py-3 text-sm font-medium text-white transition-opacity hover:opacity-85 md:mt-0"
            >
                Unlock
            </button>
            <p
                id="diary-key-status"
                class="mt-3 text-sm text-(--gray-color) md:mt-0 md:min-w-36"
                aria-live="polite"
            >
                Locked
            </p>
        </form>

        {
            entries.length === 0 ? (
                <p class="text-center text-(--gray-color) text-lg">
                    No diary entries yet.
                </p>
            ) : (
                <div class="space-y-10">
                    <section
                        class="rounded-3xl border border-black/10 bg-white/50 p-4 shadow-[0_18px_60px_rgba(15,18,25,0.08)] backdrop-blur-sm md:p-5"
                        data-diary-calendar-panel
                    >
                        <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
                            <div>
                                <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-(--gray-color)">
                                    Calendar
                                </h2>
                                <p class="mt-1 text-sm text-(--gray-color)">
                                    Select an available date to open its diary
                                    entry.
                                </p>
                            </div>
                            <p
                                id="diary-date-status"
                                class="text-sm font-medium text-(--main-color)"
                                aria-live="polite"
                            >
                                Dates with diary entries are selectable.
                            </p>
                        </div>
                        <calendar-date
                            id="diary-calendar"
                            value={maxDiaryDateKey}
                            focused-date={minDiaryDateKey}
                            min={minDiaryDateKey}
                            max={maxDiaryDateKey}
                            months="1"
                            page-by="single"
                            show-outside-days
                        >
                            <span slot="previous" aria-label="Previous month">
                                ←
                            </span>
                            <span slot="next" aria-label="Next month">
                                →
                            </span>
                            <calendar-month />
                            <calendar-month
                                data-secondary-calendar-month
                                offset="1"
                                hidden
                            />
                        </calendar-date>
                    </section>

                    <div class="space-y-8">
                        {entries.map((entry, index) => (
                            <article
                                id={entry.dateKey}
                                class="diary-card scroll-mt-24 rounded-3xl border border-black/10 bg-white/45 p-3 shadow-[0_18px_60px_rgba(15,18,25,0.08)] backdrop-blur-sm md:p-4"
                                data-diary-card={entry.dateKey}
                                data-diary-index={index}
                                hidden={
                                    !initialVisibleDateKeys.has(entry.dateKey)
                                }
                            >
                                <div
                                    class="typst-diary-svg overflow-hidden rounded-2xl bg-[#fffdf7]"
                                    data-diary-entry={entry.dateKey}
                                    aria-busy="true"
                                >
                                    <p class="m-0 text-(--gray-color)">
                                        Enter the decipher key to render this
                                        entry.
                                    </p>
                                </div>
                            </article>
                        ))}
                    </div>
                </div>
            )
        }
    </main>

    <script
        id="diary-entries"
        type="application/json"
        set:html={clientEntriesJson}
    />
</Layout>

<style>
    .diary-card {
        transition:
            transform 180ms ease,
            box-shadow 180ms ease,
            border-color 180ms ease;
    }

    .diary-card:hover {
        transform: translateY(-1px);
        border-color: rgba(0, 0, 0, 0.14);
        box-shadow: 0 22px 70px rgba(15, 18, 25, 0.11);
    }

    calendar-date {
        --color-accent: var(--main-color);
        --color-text-on-accent: white;
        display: block;
        max-width: 42rem;
        min-width: 0;
        width: 100%;
    }

    calendar-date::part(container) {
        gap: 0.9rem;
    }

    calendar-date::part(header) {
        align-items: center;
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }

    calendar-date::part(heading) {
        font-size: 1rem;
        font-weight: 600;
    }

    calendar-date::part(button) {
        border-radius: 999px;
        min-width: 2.25rem;
        padding: 0.35rem 0.65rem;
        transition:
            background 160ms ease,
            opacity 160ms ease;
    }

    calendar-date::part(button):hover {
        background: rgba(0, 0, 0, 0.08);
    }

    calendar-date::part(months) {
        display: grid;
        min-width: 0;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    }

    calendar-month[hidden] {
        display: none;
    }

    calendar-month {
        display: block;
        box-sizing: border-box;
        min-width: 0;
        width: 100%;
        border-radius: 1.25rem;
        background: #fffdf7;
        padding: 0.85rem;
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.06);
    }

    calendar-month::part(heading) {
        margin-bottom: 0.75rem;
        text-align: center;
        font-size: 1rem;
        font-weight: 650;
    }

    calendar-month::part(table) {
        table-layout: fixed;
        width: 100%;
        max-width: 100%;
        border-collapse: separate;
        border-spacing: clamp(0.12rem, 0.65vw, 0.25rem);
        font-size: clamp(0.76rem, 2.1vw, 0.86rem);
    }

    calendar-month::part(th) {
        color: var(--gray-color);
        font-size: 0.7rem;
        font-weight: 650;
        text-align: center;
        text-transform: uppercase;
    }

    calendar-month::part(td) {
        padding: 0;
    }

    calendar-month::part(button) {
        align-items: center;
        border-radius: 0.7rem;
        display: inline-flex;
        justify-content: center;
        box-sizing: border-box;
        min-height: 2.05rem;
        min-width: 0;
        padding: 0;
        width: 100%;
        transition:
            background 160ms ease,
            color 160ms ease,
            opacity 160ms ease,
            transform 160ms ease;
    }

    calendar-month::part(diary-available) {
        font-weight: 650;
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.16);
    }

    calendar-month::part(button):not(:disabled):hover {
        background: rgba(0, 0, 0, 0.08);
        transform: translateY(-1px);
    }

    calendar-month::part(selected) {
        box-shadow: none;
    }

    calendar-month::part(disallowed),
    calendar-month::part(outside) {
        opacity: 0.24;
    }

    .typst-diary-svg {
        min-height: 18rem;
    }

    .typst-diary-svg :global(svg) {
        display: block;
        width: 100%;
        height: auto;
    }
</style>

<script>
    import { decryptGitCryptSource } from "../lib/gitCrypt";
    import { createTypstCompiler } from "@myriaddreamin/typst.ts/compiler";
    import { createTypstRenderer } from "@myriaddreamin/typst.ts/renderer";
    import { preloadFontAssets } from "@myriaddreamin/typst.ts/options.init";
    import compilerWasmUrl from "@myriaddreamin/typst-ts-web-compiler/wasm?url";
    import rendererWasmUrl from "@myriaddreamin/typst-ts-renderer/wasm?url";
    import "cally";

    type CalendarDateElement = HTMLElement & {
        value: string;
        months: number;
        focusedDate?: string;
        isDateDisallowed: (date: Date) => boolean;
        getDayParts: (date: Date) => string;
        update?: () => Promise<void>;
    };

    type ClientDiarySource = {
        dateKey: string;
        source: string;
    };

    const diaryTypstPrelude = `#set page(
  width: 430pt,
  height: auto,
  margin: (x: 34pt, y: 38pt),
)
#set text(
  font: ("Libertinus Serif", "Noto Serif CJK SC"),
  size: 10.5pt,
)
#set par(
  leading: 0.72em,
  justify: true,
)
`;

    const entriesElement = document.getElementById("diary-entries");
    const entries = entriesElement?.textContent
        ? (JSON.parse(entriesElement.textContent) as ClientDiarySource[])
        : [];
    const availableDateKeys = new Set(entries.map((entry) => entry.dateKey));

    const form = document.getElementById(
        "diary-key-form",
    ) as HTMLFormElement | null;
    const keyInput = document.getElementById(
        "diary-key",
    ) as HTMLInputElement | null;
    const status = document.getElementById("diary-key-status");
    const calendar = document.getElementById(
        "diary-calendar",
    ) as CalendarDateElement | null;
    const dateStatus = document.getElementById("diary-date-status");
    const calendarPanel = document.querySelector<HTMLElement>(
        "[data-diary-calendar-panel]",
    );
    const secondaryCalendarMonth = document.querySelector<HTMLElement>(
        "[data-secondary-calendar-month]",
    );
    const twoMonthCalendarMinWidth = 640;
    const compiler = createTypstCompiler();
    const renderer = createTypstRenderer();
    let unlockedKey: string | null = null;
    let initPromise: Promise<unknown> | null = null;

    const initTypst = () => {
        initPromise ??= Promise.all([
            compiler.init({
                beforeBuild: [
                    preloadFontAssets({
                        assets: ["text", "cjk"],
                    }),
                ],
                getModule: () => compilerWasmUrl,
            }),
            renderer.init({
                getModule: () => rendererWasmUrl,
            }),
        ]);

        return initPromise;
    };

    const setStatus = (message: string) => {
        if (status) {
            status.textContent = message;
        }
    };

    const setDateStatus = (message: string) => {
        if (dateStatus) {
            dateStatus.textContent = message;
        }
    };

    const dateKeyFromDate = (date: Date) =>
        [
            date.getUTCFullYear(),
            String(date.getUTCMonth() + 1).padStart(2, "0"),
            String(date.getUTCDate()).padStart(2, "0"),
        ].join("-");

    const selectDateKey = (dateKey: string) => {
        if (location.hash.slice(1) === encodeURIComponent(dateKey)) {
            void showSelectedEntryWindow();
        } else {
            location.hash = encodeURIComponent(dateKey);
        }
    };

    const configureCalendar = () => {
        if (!calendar) {
            return;
        }

        calendar.isDateDisallowed = (date) =>
            !availableDateKeys.has(dateKeyFromDate(date));
        calendar.getDayParts = (date) =>
            availableDateKeys.has(dateKeyFromDate(date))
                ? "diary-available"
                : "";
    };

    const syncResponsiveCalendar = () => {
        if (!calendar) {
            return;
        }

        const availableWidth = calendarPanel?.clientWidth ?? window.innerWidth;
        const monthCount = availableWidth >= twoMonthCalendarMinWidth ? 2 : 1;
        calendar.months = monthCount;
        calendar.setAttribute("months", String(monthCount));
        secondaryCalendarMonth?.toggleAttribute("hidden", monthCount === 1);
        void calendar.update?.();
    };

    const decryptSource = (source: string, key: string) =>
        decryptGitCryptSource(source, key);

    const selectedIndexFromHash = () => {
        const dateKey = decodeURIComponent(location.hash.slice(1));
        const index = entries.findIndex((entry) => entry.dateKey === dateKey);
        return index === -1 ? 0 : index;
    };

    const syncSelectedControls = () => {
        const selectedIndex = selectedIndexFromHash();
        const selectedEntry = entries[selectedIndex];
        if (!selectedEntry) {
            return selectedIndex;
        }

        if (calendar) {
            calendar.value = selectedEntry.dateKey;
        }

        setDateStatus(`Selected ${selectedEntry.dateKey}.`);
        return selectedIndex;
    };

    const renderEntry = async (entry: ClientDiarySource, key: string) => {
        const container = document.querySelector<HTMLElement>(
            `[data-diary-entry="${entry.dateKey}"]`,
        );
        if (!container) {
            return;
        }

        container.setAttribute("aria-busy", "true");
        container.innerHTML = `<p class="m-0 text-(--gray-color)">Rendering diary entry…</p>`;

        const source = await decryptSource(entry.source, key);
        const mainFilePath = `/diary/${entry.dateKey}.typ`;
        compiler.addSource(mainFilePath, `${diaryTypstPrelude}\n${source}`);

        const { result: vectorData, diagnostics } = await compiler.compile({
            mainFilePath,
            diagnostics: "unix",
        });

        if (!vectorData) {
            container.removeAttribute("aria-busy");
            container.innerText =
                diagnostics?.join("\n") || "Typst compile failed.";
            return;
        }

        const svg = await renderer.renderSvg({
            format: "vector",
            artifactContent: vectorData,
        });

        container.removeAttribute("aria-busy");
        container.dataset.renderedWithKey = key;
        container.innerHTML = svg;
    };

    const showSelectedEntryWindow = async () => {
        const selectedIndex = syncSelectedControls();

        document
            .querySelectorAll<HTMLElement>("[data-diary-card]")
            .forEach((card) => {
                const index = Number(card.dataset.diaryIndex);
                card.hidden = index !== selectedIndex;
            });

        if (!unlockedKey) {
            return;
        }

        const entry = entries[selectedIndex];
        if (!entry) {
            return;
        }

        const container = document.querySelector<HTMLElement>(
            `[data-diary-entry="${entry.dateKey}"]`,
        );
        if (container?.dataset.renderedWithKey !== unlockedKey) {
            await renderEntry(entry, unlockedKey);
        }
    };

    calendar?.addEventListener("change", () => {
        const dateKey = calendar.value;
        if (dateKey && availableDateKeys.has(dateKey)) {
            selectDateKey(dateKey);
        }
    });

    if (calendarPanel && "ResizeObserver" in window) {
        const resizeObserver = new ResizeObserver(syncResponsiveCalendar);
        resizeObserver.observe(calendarPanel);
    } else {
        window.addEventListener("resize", syncResponsiveCalendar);
    }

    form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const key = keyInput?.value ?? "";
        if (!key) {
            setStatus("Key required");
            keyInput?.focus();
            return;
        }

        setStatus("Loading compiler…");
        await initTypst();

        unlockedKey = key;
        setStatus("Rendering…");
        await showSelectedEntryWindow();
        setStatus("Unlocked");
    });

    const startDiarySelection = () => {
        configureCalendar();
        syncResponsiveCalendar();
        void showSelectedEntryWindow();
    };

    if (customElements.get("calendar-date")) {
        startDiarySelection();
    } else {
        void customElements
            .whenDefined("calendar-date")
            .then(startDiarySelection);
    }
    window.addEventListener("hashchange", () => {
        void showSelectedEntryWindow();
    });
</script>
